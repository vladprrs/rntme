{
  "root": "page",
  "elements": {
    "page": {
      "type": "PageContainer",
      "props": {},
      "children": ["header", "panel"]
    },
    "header": {
      "type": "PageHeader",
      "props": {
        "eyebrow": "Project · Version",
        "title": "Queue deployment"
      }
    },
    "panel": {
      "type": "Panel",
      "props": { "title": "Target" },
      "children": ["targetId", "queue"]
    },
    "targetId": { "type": "Input", "props": { "statePath": "/form/queue/targetId", "placeholder": "Deploy target ID" } },
    "queue": { "type": "Button", "props": { "label": "Queue deployment" }, "on": { "click": { "action": "queueDeployment" } } }
  }
}
