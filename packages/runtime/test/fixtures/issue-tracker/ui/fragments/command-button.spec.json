{
  "root": "btn",
  "elements": {
    "btn": {
      "type": "Button",
      "props": {
        "label": { "$param": "label" },
        "variant": { "$param": "variant" }
      },
      "on": {
        "press": {
          "action": "dispatch",
          "params": { "name": { "$param": "actionName" } }
        }
      }
    }
  }
}
