{
  "root": "page",
  "elements": {
    "page": {
      "type": "PlatformPage",
      "props": {},
      "children": ["header", "summary", "uiComponentsPanel"]
    },
    "header": {
      "type": "PlatformPageHeader",
      "props": {
        "eyebrow": "Project · UI",
        "title": "UI components",
        "meta": [
          { "label": "Source", "value": "Latest published bundle" }
        ],
        "actions": [
          {
            "label": "Back to project",
            "variant": "ghost",
            "hrefTemplate": "/{orgId}/projects/{projectId}"
          },
          {
            "label": "Data model",
            "variant": "secondary",
            "hrefTemplate": "/{orgId}/projects/{projectId}/data-model"
          },
          {
            "label": "API",
            "variant": "secondary",
            "hrefTemplate": "/{orgId}/projects/{projectId}/api"
          },
          {
            "label": "Graph",
            "variant": "secondary",
            "hrefTemplate": "/{orgId}/projects/{projectId}/graph"
          }
        ]
      }
    },
    "summary": {
      "type": "PlatformSummaryGrid",
      "props": {
        "statePath": "/data/summary"
      }
    },
    "uiComponentsPanel": {
      "type": "PlatformPanel",
      "props": {
        "title": "UI component definitions",
        "subtitle": "Definition inspection of each *.spec.json artifact — no live preview"
      },
      "children": ["uiComponentsTable"]
    },
    "uiComponentsTable": {
      "type": "PlatformDataTable",
      "props": {
        "statePath": "/data/uiComponents",
        "columns": [
          { "key": "kind", "label": "Kind" },
          { "key": "name", "label": "Component" },
          { "key": "path", "label": "Artifact path" }
        ]
      }
    }
  }
}
