{
  "name": "@rntme/ui-runtime",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Hono sub-router + SPA runtime that bridges @rntme/ui artifacts to HTTP bindings via json-render.",
  "exports": {
    ".":        { "types": "./dist/index.d.ts",        "import": "./dist/index.js" },
    "./server": { "types": "./dist/server/index.d.ts", "import": "./dist/server/index.js" },
    "./client": { "types": "./dist/client/index.d.ts", "import": "./dist/client/index.js" }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "build", "README.md"],
  "scripts": {
    "build":        "tsc -p tsconfig.json && pnpm run build:client",
    "build:client": "tsx src/build.ts",
    "test":         "vitest run",
    "test:watch":   "vitest",
    "typecheck":    "tsc -p tsconfig.check.json",
    "lint":         "eslint \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\"",
    "format":       "prettier --write ."
  },
  "dependencies": {
    "@json-render/core": "^0.17.0",
    "@json-render/react": "^0.17.0",
    "@json-render/shadcn": "^0.17.0",
    "@rntme/ui": "workspace:*",
    "hono": "^4.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@rntme/bindings": "workspace:*"
  },
  "devDependencies": {
    "@rntme/bindings": "workspace:*",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "esbuild": "^0.23.0",
    "eslint": "^9.10.0",
    "happy-dom": "^15.7.4",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
