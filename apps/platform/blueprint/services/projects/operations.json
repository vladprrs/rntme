{
  "version": "1",
  "operations": {
    "publishProjectBundle": {
      "handler": {
        "kind": "native",
        "entry": "./handlers/publish-project-bundle.ts",
        "export": "publishProjectBundleHandler"
      },
      "input": {
        "authorization": { "type": "string", "mode": "required" },
        "projectId": { "type": "string", "mode": "required" },
        "bodyBytes": { "type": "bytes", "mode": "required" }
      },
      "output": { "type": "PublishProjectBundleResult" },
      "effect": "write",
      "idempotency": "digest"
    },
    "listProjects": {
      "handler": {
        "kind": "native",
        "entry": "./handlers/list-org-projects.ts",
        "export": "listOrgProjectsHandler"
      },
      "input": {
        "authorization": { "type": "string", "mode": "required" },
        "organizationId": { "type": "string", "mode": "required" },
        "limit": { "type": "integer", "mode": "optional" }
      },
      "output": { "type": "ListOrgProjectsResult" },
      "effect": "read",
      "idempotency": "none"
    }
  }
}
