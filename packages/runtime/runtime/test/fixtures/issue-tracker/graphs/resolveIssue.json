{
  "id": "resolveIssue",
  "signature": {
    "inputs": {
      "issueId": {
        "type": "integer",
        "mode": "required"
      },
      "resolvedAt": {
        "type": "datetime",
        "mode": "required"
      }
    },
    "output": {
      "type": "row<IssueMutationResult>",
      "from": "out"
    }
  },
  "nodes": [
    {
      "id": "emit",
      "type": "emit",
      "config": {
        "aggregate": "Issue",
        "aggregateId": {
          "$param": "issueId"
        },
        "transition": "resolve",
        "payload": {
          "resolvedAt": {
            "$param": "resolvedAt"
          }
        }
      }
    },
    {
      "id": "out",
      "type": "result",
      "value": {
        "version": {
          "$ref": "emit.version"
        },
        "aggregateId": {
          "$ref": "emit.aggregateId"
        }
      }
    }
  ]
}
