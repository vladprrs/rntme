{
  "root": "page",
  "elements": {
    "page": {
      "type": "PlatformPage",
      "props": {},
      "children": ["header", "summary", "dashGrid"]
    },
    "header": {
      "type": "PlatformPageHeader",
      "props": {
        "eyebrow": "Project · Dashboard",
        "title": "Project overview",
        "statePath": "/data/versions",
        "meta": [
          { "label": "Environment", "value": "Preview" },
          { "label": "Published by", "value": "CLI" }
        ],
        "actions": [
          {
            "label": "Data model",
            "variant": "secondary",
            "hrefTemplate": "/{orgId}/projects/{projectId}/data-model"
          },
          {
            "label": "API",
            "variant": "primary",
            "hrefTemplate": "/{orgId}/projects/{projectId}/api"
          },
          {
            "label": "UI",
            "variant": "secondary",
            "hrefTemplate": "/{orgId}/projects/{projectId}/ui"
          },
          {
            "label": "Graph",
            "variant": "secondary",
            "hrefTemplate": "/{orgId}/projects/{projectId}/graph"
          }
        ]
      }
    },
    "summary": {
      "type": "PlatformSummaryGrid",
      "props": {
        "statePath": "/data/summary"
      }
    },
    "dashGrid": {
      "type": "PlatformBox",
      "props": { "className": "rntme-dash-grid" },
      "children": ["servicesPanel", "sidePanel"]
    },
    "servicesPanel": {
      "type": "PlatformServicesPanel",
      "props": {
        "title": "Services",
        "subtitle": "Authored as platform blueprint",
        "statePath": "/data/services"
      }
    },
    "sidePanel": {
      "type": "PlatformBox",
      "props": { "className": "rntme-side-stack" },
      "children": ["deployPanel", "alertsPanel", "versionsPanel"]
    },
    "deployPanel": {
      "type": "PlatformPanel",
      "props": { "title": "Recent deployments", "subtitle": "Latest 10" },
      "children": ["deployTimeline"]
    },
    "deployTimeline": {
      "type": "PlatformDataTable",
      "props": {
        "statePath": "/data/deployments",
        "columns": [
          { "key": "status", "label": "Status" },
          { "key": "targetId", "label": "Target" },
          { "key": "projectVersionId", "label": "Version" },
          { "key": "createdAt", "label": "Created" }
        ]
      }
    },
    "alertsPanel": {
      "type": "PlatformPanel",
      "props": { "title": "Alerts" },
      "children": ["alertsList"]
    },
    "alertsList": {
      "type": "PlatformAlertList",
      "props": {
        "variant": "warn",
        "items": [
          {
            "title": "No active warnings",
            "message": "Runtime is healthy. Warnings appear here when a binding falls back to a default."
          }
        ]
      }
    },
    "versionsPanel": {
      "type": "PlatformPanel",
      "props": { "title": "Versions", "subtitle": "Latest 100" },
      "children": ["versionsTable"]
    },
    "versionsTable": {
      "type": "PlatformDataTable",
      "props": {
        "statePath": "/data/versions",
        "columns": [
          { "key": "sequence", "label": "#" },
          { "key": "status", "label": "Status" },
          { "key": "createdAt", "label": "Created" }
        ]
      }
    }
  }
}
