{
  "root": "page",
  "elements": {
    "page": {
      "type": "PlatformPage",
      "props": {},
      "children": ["header", "summary", "endpointsExplorer"]
    },
    "header": {
      "type": "PlatformPageHeader",
      "props": {
        "eyebrow": "Project · API",
        "title": "HTTP endpoints",
        "meta": [
          { "label": "Source", "value": "Latest published bundle" }
        ]
      }
    },
    "summary": {
      "type": "PlatformSummaryGrid",
      "props": {
        "statePath": "/data/summary"
      }
    },
    "endpointsExplorer": {
      "type": "PlatformAPIExplorer",
      "props": {
        "endpointsStatePath": "/data/endpoints",
        "summaryStatePath": "/data/summary",
        "endpointDetailPathTemplate": "/api/projects/{projectId}/endpoints/{service}/{operation}"
      }
    }
  }
}
