{
  "name": "@rntme/pre-step-demo",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Demo: pre-step middleware with fake payments module.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:deps": "pnpm -r --filter @rntme/pre-step-demo... --sequential run build",
    "start": "pnpm run build:deps && tsx src/server.ts",
    "test": "pnpm run build:deps && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@rntme/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "protobufjs": "^7.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
