{
  "name": "@rntme/presentation-md-mermaid",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Markdown + Mermaid UI module for rntme.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./module.json": "./module.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "module.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm build && vitest run",
    "typecheck": "tsc -p tsconfig.check.json",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "mermaid": "^11.4.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "peerDependencies": {
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "eslint": "^9.10.0",
    "react": "^19.2.5",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1",
    "react-dom": "^19.2.5"
  }
}
