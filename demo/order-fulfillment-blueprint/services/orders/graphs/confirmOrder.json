{
  "id": "confirmOrder",
  "signature": {
    "inputs": {
      "orderId": {
        "type": "string",
        "mode": "required"
      },
      "reservationId": {
        "type": "string",
        "mode": "required"
      }
    },
    "output": {
      "type": "row<OrderActionResult>",
      "from": "out"
    }
  },
  "nodes": [
    {
      "id": "emit",
      "type": "emit",
      "config": {
        "aggregate": "Order",
        "aggregateId": {
          "$param": "orderId"
        },
        "transition": "confirm",
        "payload": {
          "reservationId": {
            "$param": "reservationId"
          }
        }
      }
    },
    {
      "id": "out",
      "type": "result",
      "value": {
        "orderId": {
          "$ref": "emit.aggregateId"
        },
        "version": {
          "$ref": "emit.version"
        }
      }
    }
  ]
}
