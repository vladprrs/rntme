{
  "root": "page",
  "elements": {
    "page": {
      "type": "PlatformPage",
      "props": {},
      "children": ["header", "form", "list"]
    },
    "header": {
      "type": "PlatformPageHeader",
      "props": {
        "eyebrow": "Organization · Deploy targets",
        "title": "Deploy targets"
      }
    },
    "form": {
      "type": "PlatformPanel",
      "props": { "title": "Add target" },
      "children": ["slug", "provider", "environment", "configJson", "create"]
    },
    "slug": { "type": "Input", "props": { "statePath": "/form/target/slug", "placeholder": "Target slug" } },
    "provider": { "type": "Input", "props": { "statePath": "/form/target/provider", "placeholder": "Provider (e.g. dokploy)" } },
    "environment": { "type": "Input", "props": { "statePath": "/form/target/environment", "placeholder": "Environment (e.g. production)" } },
    "configJson": { "type": "Input", "props": { "statePath": "/form/target/configJson", "placeholder": "{}" } },
    "create": { "type": "Button", "props": { "label": "Create" }, "on": { "click": { "action": "createDeployTarget" } } },
    "list": {
      "type": "PlatformPanel",
      "props": { "title": "All targets" },
      "children": ["targets"]
    },
    "targets": {
      "type": "PlatformDataTable",
      "props": {
        "statePath": "/data/targets",
        "columns": [
          { "key": "slug", "label": "Slug" },
          { "key": "provider", "label": "Provider" },
          { "key": "environment", "label": "Environment" }
        ]
      }
    }
  }
}
