{
  "name": "notes-demo",
  "services": ["app", "identity-auth0"],
  "routes": {
    "ui": {
      "/": "app"
    },
    "http": {
      "/api": "app"
    }
  },
  "middleware": {
    "requestContext": { "kind": "request-context" },
    "auth": {
      "kind": "auth",
      "provider": "auth0",
      "audience": "https://notes-demo.rntme.com/api",
      "moduleSlug": "identity-auth0"
    }
  },
  "mounts": [
    { "target": "ui:/", "use": ["requestContext"] },
    { "target": "http:/api", "use": ["requestContext", "auth"] }
  ]
}
