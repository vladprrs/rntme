{
  "name": "cv-extract",
  "services": ["app", "openrouter", "storage-s3"],
  "vars": {
    "MARKETING_DOMAIN": { "from": "target.modules.marketing.primaryDomain", "required": true }
  },
  "modules": {
    "openrouter": {
      "package": "@rntme/ai-llm-openrouter",
      "publicConfig": {
        "defaultModel": "openrouter/deepseek/deepseek-v4-flash",
        "timeoutMs": 30000
      }
    },
    "storage": {
      "package": "@rntme/storage-s3",
      "publicConfig": {
        "backend": "rustfs",
        "bucketName": "cv-extract-files",
        "region": "us-east-1"
      }
    },
    "marketing": {
      "package": "@rntme/marketing-site-static",
      "publicConfig": {
        "source": {
          "kind": "project-folder",
          "path": "landing"
        },
        "primaryDomain": "${MARKETING_DOMAIN}",
        "ssl": "auto"
      }
    }
  },
  "routes": {
    "ui": {
      "/": "app"
    },
    "http": {
      "/api": "app"
    }
  }
}
