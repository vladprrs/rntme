{
  "root": "shell",
  "elements": {
    "shell": {
      "type": "PlatformBox",
      "props": { "className": "rntme-app" },
      "children": ["sidebar", "main"]
    },
    "sidebar": {
      "type": "PlatformSidebar",
      "props": {
        "brand": "rntme",
        "version": "v0.3",
        "contextLabel": "Platform",
        "contextName": "rntme control plane",
        "contextMeta": "Preview · v0.3.2",
        "cliVersion": "0.3.2",
        "items": [
          {
            "label": "Dashboard",
            "hrefTemplate": "/{orgId}",
            "section": "Project"
          },
          {
            "label": "Projects",
            "hrefTemplate": "/{orgId}",
            "matchPattern": "/{orgId}/projects",
            "section": "Project"
          },
          {
            "label": "Deployments",
            "hrefTemplate": "/{orgId}/projects/{projectId}/deployments",
            "matchPattern": "/{orgId}/projects/{projectId}/deployments",
            "section": "Project"
          },
          {
            "label": "Deploy targets",
            "hrefTemplate": "/{orgId}/deploy-targets",
            "matchPattern": "/{orgId}/deploy-targets",
            "section": "Project"
          },
          {
            "label": "API tokens",
            "hrefTemplate": "/{orgId}/tokens",
            "matchPattern": "/{orgId}/tokens",
            "section": "Account"
          },
          {
            "label": "Audit log",
            "hrefTemplate": "/{orgId}/audit",
            "matchPattern": "/{orgId}/audit",
            "section": "Account"
          }
        ]
      }
    },
    "main": {
      "type": "PlatformBox",
      "props": { "className": "rntme-main" },
      "children": ["topbar", "content"]
    },
    "topbar": {
      "type": "PlatformTopbar",
      "props": {
        "crumbsFromRoute": true,
        "actions": [
          { "label": "Docs", "variant": "ghost", "href": "#" }
        ]
      }
    },
    "content": { "type": "Slot", "props": {} }
  }
}
