{
  "id": "extractResume",
  "signature": {
    "inputs": {
      "resumeId":  { "type": "string", "mode": "required" },
      "filename":  { "type": "string", "mode": "required" },
      "mediaType": { "type": "string", "mode": "required" },
      "fileId":    { "type": "string", "mode": "required" },
      "objectKey": { "type": "string", "mode": "required" }
    },
    "output": { "type": "row<ResumeActionResult>", "from": "out" }
  },
  "nodes": [
    {
      "id": "download",
      "type": "call",
      "target": { "module": "storage", "operation": "GetDownloadUrl" },
      "input": {
        "context": { "$literal": { "idempotencyKey": "" } },
        "file_id": { "$param": "fileId" },
        "ttl_sec": { "$literal": 900 }
      },
      "policy": {
        "timeoutMs": 5000,
        "retry": { "attempts": 1, "retryOn": "transient" },
        "idempotency": { "mode": "none" },
        "onError": "fail"
      }
    },
    {
      "id": "completion",
      "type": "call",
      "target": { "module": "openrouter", "operation": "Complete" },
      "input": {
        "context": {
          "idempotency_key": {
            "concat": [
              { "$literal": "cv-extract-demo-complete:" },
              { "$param": "resumeId" }
            ]
          }
        },
        "model": { "$literal": "openrouter/deepseek/deepseek-v4-flash" },
        "messages": [
          {
            "role": { "$literal": "user" },
            "content": [
              {
                "type": { "$literal": 4 },
                "file": {
                  "filename": { "$param": "filename" },
                  "media_type": { "$param": "mediaType" },
                  "url": { "$ref": "download.result.presigned.url" }
                }
              },
              {
                "type": { "$literal": 1 },
                "text": {
                  "text": { "$literal": "Extract the candidate's information from the attached resume PDF as a JSON object matching the provided schema. Output ONLY the JSON; no preamble." }
                }
              }
            ]
          }
        ],
        "sampling": {
          "response_format": { "$literal": "json_schema" },
          "response_schema": {
            "fields": {
              "type": { "stringValue": { "$literal": "object" } },
              "additionalProperties": { "boolValue": { "$literal": false } },
              "properties": {
                "structValue": {
                  "fields": {
                    "full_name": {
                      "structValue": {
                        "fields": {
                          "type": { "stringValue": { "$literal": "string" } }
                        }
                      }
                    },
                    "experience": {
                      "structValue": {
                        "fields": {
                          "type": { "stringValue": { "$literal": "array" } },
                          "items": {
                            "structValue": {
                              "fields": {
                                "type": { "stringValue": { "$literal": "object" } },
                                "additionalProperties": { "boolValue": { "$literal": false } },
                                "properties": {
                                  "structValue": {
                                    "fields": {
                                      "company": {
                                        "structValue": {
                                          "fields": {
                                            "type": { "stringValue": { "$literal": "string" } }
                                          }
                                        }
                                      },
                                      "title": {
                                        "structValue": {
                                          "fields": {
                                            "type": { "stringValue": { "$literal": "string" } }
                                          }
                                        }
                                      },
                                      "start_date": {
                                        "structValue": {
                                          "fields": {
                                            "type": { "stringValue": { "$literal": "string" } }
                                          }
                                        }
                                      },
                                      "end_date": {
                                        "structValue": {
                                          "fields": {
                                            "type": { "stringValue": { "$literal": "string" } }
                                          }
                                        }
                                      }
                                    }
                                  }
                                },
                                "required": {
                                  "listValue": {
                                    "values": [
                                      { "stringValue": { "$literal": "company" } },
                                      { "stringValue": { "$literal": "title" } }
                                    ]
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    "education": {
                      "structValue": {
                        "fields": {
                          "type": { "stringValue": { "$literal": "array" } },
                          "items": {
                            "structValue": {
                              "fields": {
                                "type": { "stringValue": { "$literal": "object" } },
                                "additionalProperties": { "boolValue": { "$literal": false } },
                                "properties": {
                                  "structValue": {
                                    "fields": {
                                      "institution": {
                                        "structValue": {
                                          "fields": {
                                            "type": { "stringValue": { "$literal": "string" } }
                                          }
                                        }
                                      },
                                      "degree": {
                                        "structValue": {
                                          "fields": {
                                            "type": { "stringValue": { "$literal": "string" } }
                                          }
                                        }
                                      },
                                      "year": {
                                        "structValue": {
                                          "fields": {
                                            "type": { "stringValue": { "$literal": "string" } }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    "skills": {
                      "structValue": {
                        "fields": {
                          "type": { "stringValue": { "$literal": "array" } },
                          "items": {
                            "structValue": {
                              "fields": {
                                "type": { "stringValue": { "$literal": "string" } }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "required": {
                "listValue": {
                  "values": [
                    { "stringValue": { "$literal": "full_name" } },
                    { "stringValue": { "$literal": "experience" } }
                  ]
                }
              }
            }
          }
        }
      },
      "policy": {
        "timeoutMs": 30000,
        "retry":   { "attempts": 1, "retryOn": "transient" },
        "idempotency": { "mode": "derive" },
        "onError": "fail"
      }
    },
    {
      "id": "emit",
      "type": "emit",
      "config": {
        "aggregate": "Resume",
        "aggregateId": { "$param": "resumeId" },
        "transition": "complete",
        "payload": {
          "filename":      { "$param": "filename" },
          "mediaType":     { "$param": "mediaType" },
          "fileId":        { "$param": "fileId" },
          "objectKey":     { "$param": "objectKey" },
          "downloadUrl":   { "$ref": "download.result.presigned.url" },
          "extractedJson": { "$ref": "completion.result.content[0].text.text" }
        }
      }
    },
    {
      "id": "out",
      "type": "result",
      "value": { "resumeId": { "$ref": "emit.aggregateId" } }
    }
  ]
}
