{
  "id": "createToken",
  "signature": {
    "inputs": {
      "authorization": { "type": "string", "mode": "required" },
      "organizationId": { "type": "string", "mode": "required" },
      "name": { "type": "string", "mode": "required" },
      "prefix": { "type": "string", "mode": "required" },
      "scopesJson": { "type": "string", "mode": "required" }
    },
    "output": { "type": "row<ActionResult>", "from": "out" }
  },
  "nodes": [
    {
      "id": "session",
      "type": "call",
      "target": {
        "module": "identity-auth0",
        "operation": "IntrospectSession"
      },
      "input": {
        "token": { "$param": "authorization" },
        "audience": { "$literal": "${auth.audience}" }
      },
      "policy": {
        "timeoutMs": 1000,
        "retry": { "attempts": 2, "retryOn": "transient" },
        "idempotency": { "mode": "none" },
        "onError": "fail"
      }
    },
    { "id": "newId", "type": "uuid", "config": {} },
    {
      "id": "emit",
      "type": "emit",
      "config": {
        "aggregate": "ApiToken",
        "aggregateId": { "$node": "newId" },
        "transition": "create",
        "payload": {
          "organizationId": { "$param": "organizationId" },
          "name": { "$param": "name" },
          "prefix": { "$param": "prefix" },
          "scopesJson": { "$param": "scopesJson" }
        }
      }
    },
    {
      "id": "out",
      "type": "result",
      "value": { "id": { "$ref": "emit.aggregateId" }, "version": { "$ref": "emit.version" } }
    }
  ]
}
