{
  "id": "getResume",
  "signature": {
    "inputs": {
      "id": { "type": "string", "mode": "required" }
    },
    "output": { "type": "row<ResumeView>", "from": "out" }
  },
  "nodes": [
    {
      "id": "resume",
      "type": "findOne",
      "config": {
        "source": { "projection": "ResumeView" },
        "where": { "eq": ["resumeView.id", { "$param": "id" }] }
      }
    },
    { "id": "out", "type": "result", "value": { "$ref": "resume" } }
  ]
}
