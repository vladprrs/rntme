{
  "root": "page",
  "elements": {
    "page": {
      "type": "PlatformPage",
      "props": {},
      "children": ["header", "form", "list"]
    },
    "header": {
      "type": "PlatformPageHeader",
      "props": {
        "eyebrow": "Organization · API tokens",
        "title": "API tokens"
      }
    },
    "form": {
      "type": "PlatformPanel",
      "props": { "title": "Issue token" },
      "children": ["issuer"]
    },
    "issuer": {
      "type": "PlatformTokenIssuer",
      "props": {
        "defaultName": "cv-extract-deploy",
        "defaultScopesJson": "[\"project:read\",\"project:write\",\"version:publish\",\"deploy:execute\",\"deploy:target:manage\"]"
      }
    },
    "list": {
      "type": "PlatformPanel",
      "props": { "title": "All tokens" },
      "children": ["tokens"]
    },
    "tokens": {
      "type": "PlatformDataTable",
      "props": {
        "statePath": "/data/tokens",
        "columns": [
          { "key": "name", "label": "Name" },
          { "key": "prefix", "label": "Prefix" },
          { "key": "status", "label": "Status" }
        ]
      }
    }
  }
}
