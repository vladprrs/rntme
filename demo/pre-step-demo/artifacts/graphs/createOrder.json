{
  "id": "createOrder",
  "signature": {
    "inputs": {
      "orderId": { "type": "integer", "mode": "required" },
      "userId": { "type": "string", "mode": "required" },
      "amount": { "type": "integer", "mode": "required" },
      "customerId": { "type": "string", "mode": "nullable" }
    },
    "output": { "type": "row<CommandResult>", "from": "emit" }
  },
  "nodes": [
    {
      "id": "emit",
      "type": "emit",
      "config": {
        "aggregate": "Order",
        "aggregateId": { "$param": "orderId" },
        "transition": "create",
        "payload": {
          "customerId": { "$param": "customerId" },
          "userId": { "$param": "userId" },
          "amount": { "$param": "amount" }
        }
      }
    }
  ]
}
