{
  "name": "rntme",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for rntme — a typed read-side query language and its compilers.",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "validate:issue-tracker-seed": "rntme-seed validate demo/issue-tracker-api/artifacts"
  },
  "devDependencies": {
    "@rntme/seed": "workspace:*"
  }
}
