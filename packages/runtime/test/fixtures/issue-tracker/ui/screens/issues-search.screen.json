{
  "metadata": { "title": "Search" },
  "data": {
    "/data/results": {
      "binding": "searchIssues",
      "params": {
        "q": { "$state": "/form/q" },
        "from": { "$state": "/form/from" },
        "to": { "$state": "/form/to" },
        "priority": { "$state": "/form/priority" },
        "limit": { "$state": "/form/limit" }
      }
    }
  },
  "actions": {
    "search": {
      "kind": "refetch",
      "targets": ["/data/results"]
    }
  }
}
