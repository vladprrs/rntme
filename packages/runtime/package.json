{
  "name": "@rntme/runtime",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Zero-code runtime for rntme services: consumes PDM/QSM/graphs/bindings/ui + manifest.json and serves HTTP.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapter-client": {
      "types": "./dist/plugins/adapter-client/index.d.ts",
      "import": "./dist/plugins/adapter-client/index.js"
    },
    "./observability": {
      "types": "./dist/plugins/observability.d.ts",
      "import": "./dist/plugins/observability.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rntme-runtime": "./dist/bin/runtime.js"
  },
  "files": [
    "dist",
    "README.md",
    "Dockerfile.template"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.check.json",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@hono/node-server": "^1.13.0",
    "@rntme/bindings": "workspace:*",
    "@rntme/bindings-grpc": "workspace:*",
    "@rntme/bindings-http": "workspace:*",
    "@rntme/db-studio": "workspace:*",
    "@rntme/event-store": "workspace:*",
    "@rntme/graph-ir-compiler": "workspace:*",
    "@rntme/pdm": "workspace:*",
    "@rntme/projection-consumer": "workspace:*",
    "@rntme/qsm": "workspace:*",
    "@rntme/seed": "workspace:^",
    "@rntme/ui": "workspace:*",
    "@rntme/ui-runtime": "workspace:*",
    "@grpc/proto-loader": "^0.7.13",
    "@types/protobufjs": "^6.0.0",
    "hono": "^4.6.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "protobufjs": "^8.0.1",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "better-sqlite3": "^11.0.0",
    "eslint": "^9.10.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
