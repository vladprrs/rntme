{
  "root": "page",
  "elements": {
    "page": {
      "type": "PageContainer",
      "props": {},
      "children": ["header", "panel"]
    },
    "header": {
      "type": "PageHeader",
      "props": {
        "eyebrow": "Project · Deployments",
        "title": "Deployments"
      }
    },
    "panel": {
      "type": "Panel",
      "props": { "title": "All deployments", "subtitle": "Latest 100" },
      "children": ["deployments"]
    },
    "deployments": {
      "type": "DataTable",
      "props": {
        "statePath": "/data/deployments",
        "columns": [
          { "key": "id", "label": "ID" },
          { "key": "status", "label": "Status" },
          { "key": "targetId", "label": "Target" },
          { "key": "projectVersionId", "label": "Version" }
        ]
      }
    }
  }
}
