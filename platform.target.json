{
  "kind": "dokploy",
  "displayName": "rntme-platform-prod",
  "config": {
    "dokployUrl": "https://dokploy.vladpr.com",
    "dokployProjectId": "wmiyt_0T7SKvS3sr6rzGK"
  },
  "secrets": {
    "apiToken": { "source": "env", "name": "DOKPLOY_API_KEY" },
    "extras": {
      "auth0Mgmt": {
        "tenantDomain": { "source": "env", "name": "AUTH0_DOMAIN" },
        "mgmtClientId": { "source": "env", "name": "AUTH0_MANAGEMENT_CLIENT_ID" },
        "mgmtClientSecret": { "source": "env", "name": "AUTH0_MANAGEMENT_CLIENT_SECRET" }
      },
      "platform-secret-encryption-key": { "source": "env", "name": "PLATFORM_SECRET_ENCRYPTION_KEY" }
    }
  },
  "eventBus": { "kind": "kafka", "mode": "provisioned", "provider": "redpanda" },
  "workflows": {
    "engine": {
      "kind": "operaton",
      "mode": "provisioned",
      "image": "operaton/operaton:2.1.0"
    },
    "worker": {
      "image": "ghcr.io/vladprrs/rntme-bpmn-worker:runtime-e2e-platform-deployrunner-rustfs-5f47d886"
    }
  },
  "auth": {
    "auth0": {
      "domain": "demo-rntme.us.auth0.com",
      "audience": "https://platform.rntme.com/api",
      "redirectUri": "https://platform.rntme.com/auth/callback"
    }
  },
  "modules": {
    "identity-auth0": {
      "image": "ghcr.io/vladprrs/rntme-identity-auth0:identity-auth0-e2e-2e001d60-044928",
      "env": {
        "AUTH0_DOMAIN": "demo-rntme.us.auth0.com"
      }
    }
  },
  "services": {
    "deployments": {
      "secretRefs": {
        "PLATFORM_SECRET_ENCRYPTION_KEY": "platform-secret-encryption-key"
      }
    }
  },
  "policyValues": {
    "requestContext": {
      "default": {}
    },
    "bodyLimit": {
      "projectBundle": {
        "maxBodySize": "10m"
      }
    }
  },
  "runtimeImage": "ghcr.io/vladprrs/rntme-runtime:runtime-e2e-platform-deployrunner-rustfs-5f47d886",
  "publicBaseUrl": "https://platform.rntme.com"
}
