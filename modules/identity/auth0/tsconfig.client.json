{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist/client",
    "rootDir": "client",
    "skipLibCheck": true
  },
  "include": ["client/**/*.ts", "client/**/*.tsx"]
}
