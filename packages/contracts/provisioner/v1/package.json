{
  "name": "@rntme/contracts-provisioner-v1",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Provisioner runtime contract — what a vendor module's provisioner code receives, returns, and can fail with. Used by deploy orchestrators that run provisioners.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vladprrs/rntme.git",
    "directory": "packages/contracts/provisioner/v1"
  },
  "bugs": {
    "url": "https://github.com/vladprrs/rntme/issues"
  },
  "homepage": "https://github.com/vladprrs/rntme#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build:deps": "bun run -F @rntme/contracts-common-v1 build",
    "build": "bun run build:deps && tsc -p tsconfig.json",
    "test": "bun test",
    "typecheck": "bun run build:deps && tsc -p tsconfig.check.json",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@rntme/contracts-common-v1": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/bun": "latest",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "eslint": "^9.10.0",
    "typescript": "^5.5.4"
  }
}
