{
  "id": "listIssuesUi",
  "signature": {
    "inputs": {
      "limit": {
        "type": "integer",
        "mode": "defaulted",
        "default": 50
      }
    },
    "output": {
      "type": "rowset<Issue>",
      "from": "out"
    }
  },
  "nodes": [
    {
      "id": "items",
      "type": "findMany",
      "config": {
        "source": {
          "entity": "Issue"
        }
      }
    },
    {
      "id": "sorted",
      "type": "sort",
      "config": {
        "input": "items",
        "by": [
          {
            "field": "issue.createdAt",
            "dir": "desc",
            "nulls": "last"
          }
        ]
      }
    },
    {
      "id": "paged",
      "type": "limit",
      "config": {
        "input": "sorted",
        "count": {
          "$param": "limit"
        }
      }
    },
    {
      "id": "out",
      "type": "result",
      "value": {
        "$ref": "paged"
      }
    }
  ]
}
