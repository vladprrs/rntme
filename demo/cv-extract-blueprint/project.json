{
  "name": "cv-extract",
  "services": ["app", "marketing"],
  "vars": {
    "MARKETING_DOMAIN": { "from": "target.marketing.primaryDomain", "required": true }
  },
  "modules": {
    "openrouter": {
      "package": "@rntme/ai-llm-openrouter",
      "publicConfig": {
        "defaultModel": "openrouter/deepseek/deepseek-v4-flash",
        "timeoutMs": 60000
      }
    },
    "marketing": {
      "package": "@rntme/marketing-site-static",
      "publicConfig": {
        "source": {
          "kind": "s3",
          "bucket": "cv-extract",
          "key": "landings/cv-extract/69f0af5e1788582091a5bfbadb8b9aae6638ee15ddbc379c6dccd5cdf2dc9144.tar.gz",
          "sha256": "69f0af5e1788582091a5bfbadb8b9aae6638ee15ddbc379c6dccd5cdf2dc9144"
        },
        "primaryDomain": "${MARKETING_DOMAIN}",
        "ssl": "auto"
      }
    }
  },
  "routes": {
    "ui": {
      "/": "app"
    },
    "http": {
      "/api": "app"
    }
  }
}
