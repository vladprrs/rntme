{
  "version": "1.0",
  "graphSpecRef": "../graphs",
  "pdmRef": "../../../pdm",
  "qsmRef": "../qsm",
  "bindings": {
    "prepareResumeFileUpload": {
      "graph": "prepareResumeFileUpload",
      "target": { "engine": "sqlite", "dialect": "sqlite" },
      "http": {
        "method": "POST",
        "path": "/files/prepare-upload",
        "parameters": [
          { "name": "filename",     "in": "body", "bindTo": "filename",     "required": true },
          { "name": "contentType",  "in": "body", "bindTo": "contentType",  "required": true },
          { "name": "declaredSize", "in": "body", "bindTo": "declaredSize", "required": true }
        ]
      },
      "exposure": "action"
    },
    "commitResumeFileUpload": {
      "graph": "commitResumeFileUpload",
      "target": { "engine": "sqlite", "dialect": "sqlite" },
      "http": {
        "method": "POST",
        "path": "/files/commit-upload",
        "parameters": [
          { "name": "fileId", "in": "body", "bindTo": "fileId", "required": true }
        ]
      },
      "exposure": "action"
    },
    "extractResume": {
      "graph": "extractResume",
      "target": { "engine": "sqlite", "dialect": "sqlite" },
      "http": {
        "method": "POST",
        "path": "/resumes",
        "parameters": [
          { "name": "resumeId",  "in": "body", "bindTo": "resumeId",  "required": true },
          { "name": "filename",  "in": "body", "bindTo": "filename",  "required": true },
          { "name": "mediaType", "in": "body", "bindTo": "mediaType", "required": true },
          { "name": "fileId",    "in": "body", "bindTo": "fileId",    "required": true },
          { "name": "objectKey", "in": "body", "bindTo": "objectKey", "required": true }
        ]
      },
      "exposure": "action"
    },
    "getResume": {
      "graph": "getResume",
      "target": { "engine": "sqlite", "dialect": "sqlite" },
      "http": {
        "method": "GET",
        "path": "/resumes/{id}",
        "parameters": [
          { "name": "id", "in": "path", "bindTo": "id", "required": true }
        ]
      },
      "exposure": "read"
    }
  }
}
