{
  "name": "@rntme/presentation-tiptap",
  "version": "0.0.0",
  "description": "Tiptap rich text editor UI module.",
  "client": {
    "entry": "./dist/client.js",
    "components": [
      { "type": "RichTextEditor", "props": { "placeholder": { "type": "string", "required": false } } }
    ],
    "operations": [
      { "name": "toggleBold", "appliesTo": ["RichTextEditor"] },
      { "name": "toggleItalic", "appliesTo": ["RichTextEditor"] },
      {
        "name": "insertImage",
        "appliesTo": ["RichTextEditor"],
        "params": { "src": { "type": "string", "required": true } }
      }
    ]
  }
}
