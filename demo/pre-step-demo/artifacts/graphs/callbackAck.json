{
  "id": "callbackAck",
  "signature": {
    "inputs": {
      "state": { "type": "string", "mode": "required" },
      "code": { "type": "string", "mode": "required" }
    },
    "output": { "type": "row<CommandResult>", "from": "emit" }
  },
  "nodes": [
    {
      "id": "emit",
      "type": "emit",
      "config": {
        "aggregate": "Ack",
        "aggregateId": { "$param": "state" },
        "transition": "acknowledge",
        "payload": {
          "code": { "$param": "code" }
        }
      }
    }
  ]
}
