{
  "root": "page",
  "elements": {
    "page": {
      "type": "PlatformPage",
      "props": {},
      "children": ["header", "panel"]
    },
    "header": {
      "type": "PlatformPageHeader",
      "props": {
        "eyebrow": "Organization · Audit",
        "title": "Audit log"
      }
    },
    "panel": {
      "type": "PlatformPanel",
      "props": { "title": "Events", "subtitle": "Append-only stream" },
      "children": ["events"]
    },
    "events": {
      "type": "PlatformDataTable",
      "props": {
        "statePath": "/data/events",
        "columns": [
          { "key": "actorId", "label": "Actor" },
          { "key": "action", "label": "Action" },
          { "key": "targetType", "label": "Target type" },
          {
            "key": "targetId",
            "label": "Target",
            "hrefTemplateMap": {
              "typeField": "targetType",
              "byType": {
                "deployment": "/{orgId}/deployments/{targetId}",
                "project": "/{orgId}/projects/{targetId}",
                "deployTarget": "/{orgId}/deploy-targets",
                "deploy-target": "/{orgId}/deploy-targets"
              }
            }
          },
          { "key": "status", "label": "Status" },
          { "key": "createdAt", "label": "Time" }
        ]
      }
    }
  }
}
