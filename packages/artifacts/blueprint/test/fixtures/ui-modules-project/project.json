{
  "name": "product-catalog",
  "services": [
    "catalog",
    "pricing",
    "inventory",
    "app",
    "mod-workos"
  ],
  "routes": {
    "ui": {
      "/": "app"
    },
    "http": {
      "/api/catalog": "catalog",
      "/api/pricing": "pricing",
      "/api/inventory": "inventory"
    }
  },
  "middleware": {
    "requestContext": {
      "kind": "request-context"
    }
  },
  "mounts": [
    {
      "target": "ui:/",
      "use": [
        "requestContext"
      ]
    }
  ],
  "modules": {
    "presentation-md": {
      "package": "@rntme/presentation-md-mermaid"
    },
    "presentation-rte": {
      "package": "@rntme/presentation-tiptap"
    },
    "analytics": {
      "package": "@rntme/analytics-google-analytics",
      "publicConfig": {
        "measurementId": "G-INTEGRATION"
      }
    }
  }
}
