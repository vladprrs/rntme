{
  "id": "sprintBurndown",
  "signature": {
    "inputs": {
      "sprintId": { "type": "integer", "mode": "required" }
    },
    "output": { "type": "rowset<BurndownBucket>", "from": "grouped" }
  },
  "nodes": [
    { "id": "items", "type": "findMany", "config": { "source": { "entity": "Issue" } } },
    {
      "id": "filtered",
      "type": "filter",
      "config": {
        "input": "items",
        "expr": { "eq": ["issue.sprintId", { "$param": "sprintId" }] }
      }
    },
    {
      "id": "grouped",
      "type": "reduce",
      "config": {
        "input": "filtered",
        "into": "BurndownBucket",
        "group": { "status": "issue.status" },
        "measures": {
          "issueCount": { "fn": "count" },
          "totalStoryPoints": { "fn": "sum", "expr": "issue.storyPoints" }
        }
      }
    }
  ]
}
