{
  "root": "page",
  "elements": {
    "page": {
      "type": "PageContainer",
      "props": {},
      "children": ["header", "deploymentPanel", "logsPanel"]
    },
    "header": {
      "type": "PageHeader",
      "props": {
        "eyebrow": "Deployment",
        "title": "Deployment detail",
        "actions": [
          { "label": "Refresh", "variant": "secondary" }
        ]
      }
    },
    "deploymentPanel": {
      "type": "Panel",
      "props": { "title": "Record" },
      "children": ["refresh", "deploymentTable"]
    },
    "refresh": { "type": "Button", "props": { "label": "Refresh" }, "on": { "click": { "action": "refreshDeployment" } } },
    "deploymentTable": {
      "type": "DataTable",
      "props": {
        "statePath": "/data/deployment",
        "columns": [
          { "key": "id", "label": "ID" },
          { "key": "status", "label": "Status" },
          { "key": "targetId", "label": "Target" },
          { "key": "projectVersionId", "label": "Version" }
        ]
      }
    },
    "logsPanel": {
      "type": "Panel",
      "props": { "title": "Logs", "subtitle": "Latest 200" },
      "children": ["logsTable"]
    },
    "logsTable": {
      "type": "DataTable",
      "props": {
        "statePath": "/data/logs",
        "columns": [
          { "key": "level", "label": "Level" },
          { "key": "stage", "label": "Stage" },
          { "key": "message", "label": "Message" },
          { "key": "createdAt", "label": "Time" }
        ]
      }
    }
  }
}
