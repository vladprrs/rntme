{
  "version": "1",
  "operations": {
    "IntrospectToken": {
      "handler": {
        "kind": "native",
        "entry": "./handlers/introspect-token.ts",
        "export": "introspectTokenHandler"
      },
      "input": {
        "bearerToken": { "type": "string", "mode": "defaulted", "default": null }
      },
      "output": { "type": "IntrospectTokenResult" },
      "effect": "read",
      "idempotency": "none"
    }
  }
}
