{
  "name": "@rntme/analytics-google-analytics",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Google Analytics 4 UI module (analytics category).",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./module.json": "./module.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "module.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun run build:deps && bun run build && bun test",
    "build:deps": "bun run --cwd ../../../packages/contracts/analytics/v1 build && bun run --cwd ../../../packages/contracts/client-runtime/v1 build",
    "typecheck": "bun run build:deps && tsc -p tsconfig.check.json",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@rntme/contracts-analytics-v1": "workspace:*",
    "@rntme/contracts-client-runtime-v1": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/bun": "^1.2.14",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "eslint": "^9.10.0",
    "typescript": "^5.5.4"
  }
}
