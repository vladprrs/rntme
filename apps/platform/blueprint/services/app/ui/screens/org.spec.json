{
  "root": "page",
  "elements": {
    "page": {
      "type": "PlatformPage",
      "props": {},
      "children": ["header", "panel"]
    },
    "header": {
      "type": "PlatformPageHeader",
      "props": {
        "eyebrow": "Organization · Projects",
        "title": "Projects"
      }
    },
    "panel": {
      "type": "PlatformPanel",
      "props": { "title": "All projects", "subtitle": "Latest 100" },
      "children": ["projects"]
    },
    "projects": {
      "type": "PlatformDataTable",
      "props": {
        "statePath": "/data/projects",
        "columns": [
          { "key": "slug", "label": "Slug" },
          { "key": "displayName", "label": "Name" },
          { "key": "status", "label": "Status" }
        ]
      }
    }
  }
}
