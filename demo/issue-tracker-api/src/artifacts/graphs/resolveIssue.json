{
  "id": "resolveIssue",
  "signature": {
    "inputs": {
      "issueId":    { "type": "integer",  "mode": "required" },
      "resolvedAt": { "type": "datetime", "mode": "required" }
    },
    "output": { "type": "row<CommandResult>", "from": "emit" }
  },
  "nodes": [
    {
      "id": "emit",
      "type": "emit",
      "config": {
        "aggregate": "Issue",
        "aggregateId": { "$param": "issueId" },
        "transition": "resolve",
        "payload": { "resolvedAt": { "$param": "resolvedAt" } }
      }
    }
  ]
}
