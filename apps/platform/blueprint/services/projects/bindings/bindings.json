{
  "version": "1.0",
  "graphSpecRef": "../graphs",
  "pdmRef": "../../pdm",
  "qsmRef": "../qsm",
  "bindings": {
    "listProjects": {
      "graph": "listProjects",
      "target": { "engine": "native", "dialect": "platform" },
      "http": {
        "method": "GET",
        "path": "/",
        "parameters": [
          { "name": "organizationId", "in": "query", "bindTo": "organizationId", "required": true },
          { "name": "limit", "in": "query", "bindTo": "limit", "required": false }
        ]
      },
      "exposure": "read",
      "inputFrom": {
        "authorization": { "from": "header", "name": "authorization", "required": true },
        "sessionSubject": { "from": "header", "name": "x-rntme-user-sub", "required": false },
        "sessionStatus": { "from": "header", "name": "x-rntme-session-status", "required": false }
      }
    },
    "createProject": {
      "graph": "createProject",
      "target": { "engine": "sqlite", "dialect": "sqlite" },
      "http": {
        "method": "POST",
        "path": "/",
        "parameters": [
          { "name": "organizationId", "in": "body", "bindTo": "organizationId", "required": true },
          { "name": "slug", "in": "body", "bindTo": "slug", "required": true },
          { "name": "displayName", "in": "body", "bindTo": "displayName", "required": true }
        ]
      },
      "exposure": "action",
      "inputFrom": {
        "authorization": { "from": "header", "name": "authorization", "required": true }
      }
    },
    "listProjectVersions": {
