{
  "kind": "dokploy",
  "displayName": "rntme-platform-prod",
  "config": {
    "dokployUrl": "https://dokploy.example.com",
    "dokployProjectId": "wmiyt_0T7SKvS3sr6rzGK"
  },
  "secrets": {
    "apiToken": { "source": "env", "name": "DOKPLOY_API_KEY" },
    "extras": {
      "auth0Mgmt": {
        "tenantDomain": { "source": "env", "name": "AUTH0_DOMAIN" },
        "mgmtClientId": { "source": "env", "name": "AUTH0_MANAGEMENT_CLIENT_ID" },
        "mgmtClientSecret": { "source": "env", "name": "AUTH0_MANAGEMENT_CLIENT_SECRET" }
      }
    }
  },
  "eventBus": { "kind": "kafka", "mode": "provisioned", "provider": "redpanda" },
  "workflows": {
    "engine": {
      "kind": "operaton",
      "mode": "provisioned",
      "image": "operaton/operaton:2.1.0"
    },
    "worker": {
      "image": "ghcr.io/vladprrs/rntme-bpmn-worker:e2e-bpmn-4e3f55d-json-1"
    }
  },
  "auth": {
    "auth0": {
      "domain": "demo-rntme.us.auth0.com",
      "audience": "https://platform.rntme.com/api",
      "redirectUri": "https://platform.rntme.com/auth/callback"
    }
  },
  "publicBaseUrl": "https://platform.rntme.com"
}
