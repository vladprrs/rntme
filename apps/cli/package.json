{
  "name": "@rntme/cli",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "rntme CLI — create and operate rntme services from artifacts.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rntme": "./dist/bin/cli.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "bun -e \"const f='dist/bin/cli.js';const fs=require('fs');if(!fs.existsSync(f))process.exit(0);const s=fs.readFileSync(f,'utf8');if(!s.startsWith('#!'))fs.writeFileSync(f,'#!/usr/bin/env bun\\n'+s);fs.chmodSync(f,0o755);\" && bun scripts/copy-skills-assets.cjs && bun scripts/copy-platform-blueprint.cjs",
    "test": "bun run --cwd ../.. vendor:sync && bun test test/unit test/integration",
    "test:e2e": "bun test test/e2e",
    "typecheck": "tsc -p tsconfig.check.json",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write .",
    "gen:snapshots": "bun scripts/gen-skill-snapshots.cjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@rntme/bindings": "workspace:*",
    "@rntme/graph-ir-compiler": "workspace:*",
    "@rntme/pdm": "workspace:*",
    "@rntme/qsm": "workspace:*",
    "@rntme/seed": "workspace:*",
    "@types/bun": "^1.3.3",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "eslint": "^9.10.0",
    "msw": "^2.4.9",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@rntme/bindings-grpc": "workspace:*",
    "@rntme/blueprint": "workspace:*",
    "@rntme/bundle-publish": "workspace:*",
    "@rntme/deploy-bundle-input": "workspace:*",
    "@rntme/deploy-core": "workspace:*",
    "@rntme/deploy-dokploy": "workspace:*",
    "@rntme/deploy-runner": "workspace:*",
    "@rntme/platform-core": "workspace:*",
    "@truestamp/canonify": "^1.0.0",
    "zod": "^4.0.0"
  }
}
