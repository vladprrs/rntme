{
  "version": "1.0",
  "graphSpecRef": "../graphs",
  "pdmRef": "../../pdm",
  "qsmRef": "../qsm",
  "bindings": {
    "createNote": {
      "kind": "command",
      "graph": "createNote",
      "target": { "engine": "sqlite", "dialect": "sqlite" },
      "http": {
        "method": "POST",
        "path": "/notes",
        "parameters": [
          { "name": "title", "in": "body", "bindTo": "title", "required": true },
          { "name": "body", "in": "body", "bindTo": "body", "required": true }
        ]
      },
      "pre": [
        {
          "kind": "module-rpc",
          "module": "identity-auth0",
          "rpc": "IntrospectSession",
          "input": {
            "token": "$header.authorization",
            "audience": "https://notes-demo.rntme.com/api"
          },
          "bindAs": "session",
          "timeoutMs": 5000,
          "retry": { "attempts": 1, "retryOn": "never" }
        }
      ]
    },
    "deleteNote": {
      "kind": "command",
      "graph": "deleteNote",
      "target": { "engine": "sqlite", "dialect": "sqlite" },
      "http": {
        "method": "POST",
        "path": "/notes/{id}/actions/delete",
        "parameters": [
          { "name": "id", "in": "path", "bindTo": "id", "required": true }
        ]
      },
      "pre": [
        {
          "kind": "module-rpc",
          "module": "identity-auth0",
          "rpc": "IntrospectSession",
          "input": {
            "token": "$header.authorization",
            "audience": "https://notes-demo.rntme.com/api"
          },
          "bindAs": "session"
        }
      ]
    },
    "listNotes": {
      "kind": "query",
      "graph": "listNotes",
      "target": { "engine": "sqlite", "dialect": "sqlite" },
      "http": {
        "method": "GET",
        "path": "/notes",
        "parameters": [
          { "name": "limit", "in": "query", "bindTo": "limit", "required": false }
        ]
      },
      "pre": [
        {
          "kind": "module-rpc",
          "module": "identity-auth0",
          "rpc": "IntrospectSession",
          "input": {
            "token": "$header.authorization",
            "audience": "https://notes-demo.rntme.com/api"
          },
          "bindAs": "session"
        }
      ]
    },
    "getNote": {
      "kind": "query",
      "graph": "getNote",
      "target": { "engine": "sqlite", "dialect": "sqlite" },
      "http": {
        "method": "GET",
        "path": "/notes/{id}",
        "parameters": [
          { "name": "id", "in": "path", "bindTo": "id", "required": true }
        ]
      },
      "pre": [
        {
          "kind": "module-rpc",
          "module": "identity-auth0",
          "rpc": "IntrospectSession",
          "input": {
            "token": "$header.authorization",
            "audience": "https://notes-demo.rntme.com/api"
          },
          "bindAs": "session"
        }
      ]
    }
  }
}
