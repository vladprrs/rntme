{
  "name": "@rntme/issue-tracker-api-demo",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Demo: issue tracker service built from artifacts + @rntme/runtime.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:deps": "pnpm -r --filter @rntme/issue-tracker-api-demo... run build",
    "start": "pnpm run build:deps && tsx src/server.ts",
    "start:runtime-cli": "pnpm run build:deps && rntme-runtime start ./artifacts",
    "test": "pnpm run build:deps && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@rntme/db-studio": "workspace:*",
    "@rntme/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
